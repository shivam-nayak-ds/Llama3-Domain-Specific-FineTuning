# ============================================================
# Environment Variables — Copy this to .env and fill values
# NEVER commit .env to Git!
# ============================================================

# ── HuggingFace ──────────────────────────────────────────────
HF_TOKEN=hf_your_token_here                  # Get from: huggingface.co/settings/tokens

# ── WandB (Experiment Tracking) ──────────────────────────────
WANDB_API_KEY=your_wandb_api_key             # Get from: wandb.ai/settings
WANDB_PROJECT=llama3-financial-analyst
WANDB_ENTITY=your_wandb_username

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── API Security ─────────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_key_min_32_chars_long
API_KEY=your_api_key_for_clients

# ── Redis (Response Cache) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password

# ── Alerting (Optional) ──────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SMTP_HOST=smtp.gmail.com
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── Model Paths ──────────────────────────────────────────────
MODEL_OUTPUT_DIR=./models/llama3-financial-analyst
BASE_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct
